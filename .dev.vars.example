# Copy to .dev.vars and fill in. .dev.vars is gitignored.
# These override wrangler.jsonc `vars` for local `wrangler dev`, so the app uses
# your localhost callback and dev OAuth app instead of the production ones.
#
# Create a GitHub OAuth App at https://github.com/settings/developers
#   Homepage URL:               http://localhost:8787
#   Authorization callback URL: http://localhost:8787/auth/callback

APP_URL="http://localhost:8787"
GITHUB_CLIENT_ID="your_dev_oauth_app_client_id"
GITHUB_CLIENT_SECRET="your_dev_oauth_app_client_secret"

# Random 32+ char string used to derive session-cookie + OAuth-state keys AND to
# encrypt GitHub tokens at rest. Generate with: openssl rand -hex 32
SESSION_SECRET="change_me_to_a_long_random_string"

# Email is sent via the Cloudflare Email Sending `EMAIL` binding (wrangler.jsonc),
# not an API key — nothing else to configure here.
