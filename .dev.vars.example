# Copy to .dev.vars and fill in. .dev.vars is gitignored.
# Create a GitHub OAuth App at https://github.com/settings/developers
#   Homepage URL:               http://localhost:8787
#   Authorization callback URL: http://localhost:8787/auth/callback

GITHUB_CLIENT_ID="your_oauth_app_client_id"
GITHUB_CLIENT_SECRET="your_oauth_app_client_secret"

# Random 32+ char string used to sign session cookies (HMAC). Generate with:
#   openssl rand -hex 32
SESSION_SECRET="change_me_to_a_long_random_string"

# Optional: Resend API key for sending impersonation-alert emails.
# Leave unset to log alerts instead of sending them.
RESEND_API_KEY=""
