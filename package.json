{
  "name": "github-healthcheck",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "GitHub Healthcheck — sign in with GitHub and get a security report for your account and repositories, detecting the malware-distribution clone campaign documented at orchidfiles.com.",
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "wrangler dev",
    "build": "npm run build:web && npm run typecheck",
    "build:web": "vite build && node scripts/prerender.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.workers.config.ts",
    "deploy": "echo 'Production deploys run in CI on push to master (.github/workflows/deploy.yml). Do not deploy from a local machine.' && exit 1",
    "db:init": "wrangler d1 migrations apply github-healthcheck-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply github-healthcheck-db --remote",
    "db:migrations:list": "wrangler d1 migrations list github-healthcheck-db --local",
    "lint": "biome ci ."
  },
  "dependencies": {
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@cloudflare/vitest-pool-workers": "^0.6.16",
    "@cloudflare/workers-types": "^4.20260628.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^10.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "wrangler": "^4.103.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
